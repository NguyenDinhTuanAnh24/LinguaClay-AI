generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserCouponStatus {
  AVAILABLE
  USED
}

enum MediaAssetType {
  IMAGE
  AUDIO
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  role             UserRole       @default(USER)
  name             String?
  image            String?
  targetLanguage   String         @default("EN")
  proficiencyLevel String         @default("A1")
  
  // Subscription Fields
  isPro           Boolean        @default(false)
  proType         String?        // "3_MONTHS", "6_MONTHS", "1_YEAR"
  proStartDate    DateTime?
  proEndDate      DateTime?
  isActive        Boolean        @default(true)
  isBanned        Boolean        @default(false)
  themePreference String         @default("SYSTEM")
  phoneNumber     String?
  birthday        DateTime?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  progress         UserProgress[]
  exercises        Exercise[]
  writingSessions  WritingSession[]
  orders           Order[]
  userCoupons      UserCoupon[]
  createdTopics    Topic[]
  refundRequests   RefundRequest[]
  supportTickets   SupportTicket[]
  dailyStudyStats  UserDailyStudy[]
  notifications    UserNotification[]
}

model Topic {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  image         String?
  level         String
  language      String   @default("EN")
  isAIGenerated Boolean  @default(false)
  userId        String?

  owner           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  words           Word[]
  writingSessions WritingSession[]
  grammarPoints   GrammarPoint[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([isAIGenerated, userId])
}

model Word {
  id                 String         @id @default(cuid())
  original           String
  pronunciation      String?
  translation        String
  partOfSpeech       String?
  example            String?
  exampleTranslation String?
  audioUrl           String?
  difficulty         Int            @default(1)

  topicId            String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @default(now()) @updatedAt

  topic         Topic?         @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userProgress  UserProgress[]
  exercises     Exercise[]
}

model UserProgress {
  id           String    @id @default(cuid())
  userId       String
  wordId       String
  masteryLevel Int       @default(0)
  lastReviewed DateTime?
  nextReview   DateTime?
  isDifficult  Boolean   @default(false)
  personalNote String?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  user         User      @relation(fields: [userId], references: [id])
  word         Word      @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
}

model Exercise {
  id             String   @id @default(cuid())
  type           String
  question       String
  options        String[] @default([])
  correctAnswer  String
  explanation    String?
  difficulty     Int
  language       String
  isAIGenerated  Boolean  @default(false)
  content        Json?
  wordId         String?
  grammarPointId String?
  userId         String?
  sessionId      String?
  createdAt      DateTime @default(now())

  word          Word?         @relation(fields: [wordId], references: [id], onDelete: Cascade)
  grammarPoint  GrammarPoint? @relation(fields: [grammarPointId], references: [id])
  user          User?         @relation(fields: [userId], references: [id])
}

model WritingSession {
  id          String   @id @default(cuid())
  userId      String
  topicId     String
  userContent String   @db.Text
  aiFeedback  Json?
  score       Int?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  topic       Topic    @relation(fields: [topicId], references: [id])
}

model GrammarPoint {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  explanation     String   @db.Text
  example         String
  exampleSentence String?
  structure       String?
  exerciseData    Json?
  content         Json?
  level           String
  topicId         String?
  topic           Topic?   @relation(fields: [topicId], references: [id])
  exercises       Exercise[]
}

model Order {
  id              String   @id @default(cuid())
  orderCode       Int      @unique
  userId          String
  planId          String
  amount          Int
  originalAmount  Int?
  discountAmount  Int      @default(0)
  couponCode      String?
  userCouponId    String?
  status          String   @default("PENDING") // PENDING, SUCCESS, CANCELLED
  paidAt           DateTime?
  cancelledAt      DateTime?
  expiredAt        DateTime?
  verifiedAt       DateTime?
  payosTransactionId String?
  payosReference   String?
  refundStatus     String?  @default("NONE")    // NONE, PENDING, APPROVED, REJECTED
  refundReason     String?
  refundBankName   String?
  refundAccountNumber String?
  refundAccountName  String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user              User            @relation(fields: [userId], references: [id])
  userCoupon        UserCoupon?     @relation(fields: [userCouponId], references: [id], onDelete: SetNull)
  paymentEvents     PaymentEvent[]
  refundRequests    RefundRequest[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([planId, status])
  @@index([payosTransactionId])
  @@index([userCouponId])
}

model UserDailyStudy {
  id            String   @id @default(cuid())
  userId        String
  date          DateTime
  activeSeconds Int      @default(0)
  lastActiveAt  DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model PaymentEvent {
  id          String   @id @default(cuid())
  orderId     String
  eventType   String
  payosStatus String?
  source      String?
  payload     Json?
  createdAt   DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([payosStatus])
  @@index([eventType])
}

model RefundRequest {
  id            String   @id @default(cuid())
  orderId        String
  userId         String
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELED
  reason         String?
  bankName       String?
  accountNumber  String?
  accountName    String?
  processedBy    String?
  processedAt    DateTime?
  note           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int
  usageLimit      Int
  usedCount       Int      @default(0)
  expiresAt       DateTime
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userCoupons     UserCoupon[]

  @@index([isActive, expiresAt])
}

model UserCoupon {
  id         String           @id @default(cuid())
  userId     String
  couponId   String
  status     UserCouponStatus @default(AVAILABLE)
  assignedAt DateTime         @default(now())
  usedAt     DateTime?
  usedOrderId String?

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon     Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  orders     Order[]

  @@index([userId, status, assignedAt])
  @@index([couponId, status])
}

model MediaAsset {
  id        String         @id @default(cuid())
  type      MediaAssetType
  name      String
  url       String
  size      String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([type, createdAt])
}

model SupportTicket {
  id             String   @id @default(cuid())
  userId         String
  category       String
  subject        String?
  message        String   @db.Text
  attachmentUrl  String?
  status         String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  device         String?
  blockedLesson  String?
  internalNote   String?
  adminReply     String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([category, createdAt])
}

model UserNotification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  metadata  Json?
  dedupeKey String?   @unique
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt, createdAt])
}
